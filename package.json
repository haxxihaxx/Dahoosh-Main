{
  "name": "dahoosh",
  "version": "3.0.0",
  "description": "داهوش – AI-powered Grading & Education Platform",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.dahoosh.app",
    "productName": "داهوش",
    "directories": { "output": "dist" },
    "files": ["**/*", "!node_modules/.cache"],
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" },
    "linux": { "target": "AppImage" }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0"
  }
}
